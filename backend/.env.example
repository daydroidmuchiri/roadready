# ─── RoadReady Backend — Environment Variables ───────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ─── Database ──────────────────────────────────────────────────
# Local:      postgresql://postgres:password@localhost:5432/roadready
# Railway:    provided automatically as DATABASE_URL
# Supabase:   Settings → Database → Connection String (URI)
DATABASE_URL=postgresql://postgres:password@localhost:5432/roadready
# REQUIRED in production (Railway / Render / Supabase all use SSL)
DATABASE_SSL=true

# ─── Auth ─────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_IN_PRODUCTION

# ─── AI ───────────────────────────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ─── Server ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# Comma-separated origins allowed to call the API (your real domain, NOT localhost)
CLIENT_ORIGIN=https://admin.roadready.co.ke

# ─── Google Maps Platform (server-side) ───────────────────────
# console.cloud.google.com → APIs & Services → Credentials
# Enable: Distance Matrix API, Geocoding API, Directions API
GOOGLE_MAPS_SERVER_KEY=AIza...

# ─── Google Maps Platform (mobile client-side) ────────────────
# Use a DIFFERENT key from the server key — restrict to your app bundle IDs
# Enable: Maps SDK for Android, Maps SDK for iOS
EXPO_PUBLIC_GOOGLE_MAPS_KEY=AIza...

# ─── Cloudinary (Photo Upload) ────────────────────────────────
# Free tier: 25GB storage + 25GB bandwidth/month
# Sign up at: cloudinary.com (takes 2 minutes)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Africa's Talking (SMS / OTP) ─────────────────────────────
# Register at: africastalking.com
# For production: set AT_USERNAME to your live username (NOT 'sandbox')
# and set SMS_DRY_RUN=false to send real SMS messages.
AT_USERNAME=your_live_at_username
AT_API_KEY=your_live_at_api_key
AT_SENDER_ID=RoadReady        # optional branded sender ID (requires AT approval)
SMS_DRY_RUN=false             # MUST be false in production — true only for local dev

# ─── M-Pesa Daraja (STK Push — customer payments) ─────────────
# Register at: https://developer.safaricom.co.ke
# MPESA_ENV must be 'production' for live payments (not 'sandbox')
MPESA_ENV=production
MPESA_CONSUMER_KEY=your_live_consumer_key
MPESA_CONSUMER_SECRET=your_live_consumer_secret
MPESA_SHORTCODE=your_live_shortcode
MPESA_PASSKEY=your_live_passkey
# Must be a public HTTPS URL (your Railway/Render domain)
MPESA_CALLBACK_URL=https://api.roadready.co.ke/api/payments/mpesa/callback

# ─── M-Pesa B2C (provider payouts) ────────────────────────────
# Requires separate Safaricom approval for B2C payments
MPESA_B2C_INITIATOR_NAME=your_b2c_initiator_name
MPESA_B2C_SECURITY_CREDENTIAL=your_b2c_security_credential
MPESA_B2C_RESULT_URL=https://api.roadready.co.ke/api/payouts/mpesa/result
MPESA_B2C_QUEUE_TIMEOUT_URL=https://api.roadready.co.ke/api/payouts/mpesa/timeout

# ─── Firebase (Push Notifications) ────────────────────────────
# Firebase Console → Project Settings → Service Accounts → Generate new private key
# Paste the entire JSON file contents as a single-line string:
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-...@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
# Alternative: point to a local JSON file (for local dev only)
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ─── Error Tracking (Sentry) ──────────────────────────────────
# Free tier: 5,000 errors/month — sentry.io
SENTRY_DSN=https://your_key@sentry.io/your_project_id
